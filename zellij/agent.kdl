// agent cli — R1 trial layout. Session name: "agent".
// Syntax verified against the installed zellij 0.44.3's own bundled
// layouts (`zellij setup --dump-layout strider`) — plugin/pane/
// split_direction/size/borderless confirmed live. `tab`/`cwd`/`command`/
// `args`/`default_tab_template`/`children` are standard KDL-layout
// primitives, stable since zellij's KDL format shipped.
//
// One tab per active project. Each tab opens with a yazi file rail
// (25%) and one claude pane — add more agent panes ad hoc with
// zellij's own pane-splitting (Alt+n / Alt+arrows below), no
// pre-built worktree automation yet (that's P2, parked on purpose).
//
// Add a project: copy a `tab` block, change name/cwd. That's it.

layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="tab-bar"
        }
        children
        pane size=2 borderless=true {
            plugin location="status-bar"
        }
    }

    tab name="indx" cwd="/Users/jasonpoindexter/Documents/GitHub/apps/indx" {
        pane split_direction="vertical" {
            pane command="yazi" size="25%"
            pane command="claude"
        }
    }

    tab name="brutal" cwd="/Users/jasonpoindexter/Documents/GitHub/apps/brutal--active" {
        pane split_direction="vertical" {
            pane command="yazi" size="25%"
            pane command="claude"
        }
    }

    tab name="hashmark" cwd="/Users/jasonpoindexter/Documents/GitHub/apps/hashmark" {
        pane split_direction="vertical" {
            pane command="yazi" size="25%"
            pane command="claude"
        }
    }

    tab name="prova" cwd="/Users/jasonpoindexter/Documents/GitHub/apps/prova" {
        pane split_direction="vertical" {
            pane command="yazi" size="25%"
            pane command="claude"
        }
    }
}
