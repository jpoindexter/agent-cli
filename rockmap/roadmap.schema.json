{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/jpoindexter/rockmap/roadmap.schema.json",
  "title": "rockmap roadmap",
  "type": "object",
  "required": ["columns", "cards"],
  "additionalProperties": true,
  "properties": {
    "$schema": { "type": "string" },
    "title": { "type": "string", "description": "Board heading. Defaults to \"Roadmap\"." },
    "subtitle": { "type": "string", "description": "One-line meta shown under the title." },
    "loop": { "type": "string", "description": "Optional narrative line (the core loop / wedge / rule)." },
    "columns": {
      "type": "array",
      "minItems": 1,
      "description": "The board columns, left to right (e.g. Now / Next / Later).",
      "items": {
        "type": "object",
        "required": ["id", "label"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "color": { "type": "string", "description": "CSS color for the column heading." }
        }
      }
    },
    "tiers": {
      "type": "array",
      "description": "Optional priority bands within each column (e.g. Rocks / Pebbles / Sand).",
      "items": {
        "type": "object",
        "required": ["id", "label"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "color": { "type": "string" }
        }
      }
    },
    "tracks": {
      "type": "array",
      "description": "Workstreams / lenses. Each renders as a colored chip + a legend entry + a filter.",
      "items": {
        "type": "object",
        "required": ["id", "label", "color"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "color": { "type": "string", "description": "Chip text color." },
          "border": { "type": "string", "description": "Chip border color. Defaults to color." },
          "bg": { "type": "string", "description": "Chip background. Defaults to transparent." }
        }
      }
    },
    "launches": {
      "type": "array",
      "description": "Release buckets for the launch filter (e.g. v1 / v2). Inferred from cards if omitted.",
      "items": {
        "type": "object",
        "required": ["id", "label"],
        "properties": { "id": { "type": "string" }, "label": { "type": "string" } }
      }
    },
    "models": {
      "type": "array",
      "description": "Optional executor/model badges (e.g. who or what builds each slice).",
      "items": {
        "type": "object",
        "required": ["id", "color"],
        "properties": { "id": { "type": "string" }, "color": { "type": "string" } }
      }
    },
    "cards": {
      "type": "array",
      "description": "The roadmap slices.",
      "items": { "$ref": "#/$defs/card" }
    },
    "shipped": {
      "type": "array",
      "description": "Completed slices, shown dimmed in a collapsible section.",
      "items": { "$ref": "#/$defs/card" }
    }
  },
  "$defs": {
    "card": {
      "type": "object",
      "required": ["id", "title"],
      "properties": {
        "id": { "type": "string", "description": "Short stable id, shown before the title." },
        "title": { "type": "string" },
        "column": { "type": "string", "description": "Column id. Required for cards (not for shipped)." },
        "tier": { "type": "string", "description": "Tier id." },
        "track": { "type": "string", "description": "Track id." },
        "size": { "type": "string", "enum": ["S", "M", "L"], "description": "T-shirt size." },
        "launch": { "type": "string", "description": "Launch bucket id." },
        "model": { "type": "string", "description": "Model/executor badge id." },
        "effort": { "type": "string", "description": "Free text shown next to the model badge (e.g. high)." },
        "blocker": { "type": "boolean", "description": "Marks a 🔒 launch blocker." },
        "gated": { "type": "boolean", "description": "Marks a ⊘ externally-gated slice." },
        "summary": { "type": "string" },
        "done": { "type": "string", "description": "Definition of done (collapsible)." },
        "closes": { "type": "string", "description": "Footer line, e.g. which gaps/risks it closes." },
        "shipped": { "type": "string", "description": "Date string appended to done for shipped cards." }
      }
    }
  }
}
